  <!-- FRONT WHEELS (Master: Publishes Odom, No TF) -->

  <!-- modified to take the odom from the ekf instead of diff drive -->
    <plugin filename="libignition-gazebo-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>Wheel4J</left_joint>
      <right_joint>Wheel1J</right_joint>
      <wheel_separation>0.866</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      
      <!-- FIXED: Changed from 1 to 30 for smoother EKF -->
      <odom_publish_frequency>30</odom_publish_frequency>
      
      <topic>/cmd_vel</topic>
      <odom_topic>/odometry</odom_topic>
      
      <!-- DELETED: <tf_topic>/tf</tf_topic> so it stops fighting RViz -->
      
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      
      <max_linear_acceleration>20.0</max_linear_acceleration>
      <min_linear_acceleration>-20.0</min_linear_acceleration>
      <max_angular_acceleration>20.0</max_angular_acceleration>
      <min_angular_acceleration>-20.0</min_angular_acceleration>
      <max_linear_velocity>4.0</max_linear_velocity>
      <min_linear_velocity>-4.0</min_linear_velocity>
      <max_angular_velocity>4.0</max_angular_velocity>
      <min_angular_velocity>-4.0</min_angular_velocity>
    </plugin>

    <!-- REAR WHEELS (Slave: Drives motors, Ignores Odom) -->
    <plugin filename="libignition-gazebo-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>Wheel3J</left_joint>
      <right_joint>Wheel2J</right_joint>
      <wheel_separation>0.866</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      
      <odom_publish_frequency>30</odom_publish_frequency>
      
      <topic>/cmd_vel</topic>
      
      <!-- SAFETY: Send this to a dummy topic so it doesn't double-count odom -->
      <odom_topic>/odometry_rear_ignore</odom_topic>
      
      <max_linear_acceleration>20.0</max_linear_acceleration>
      <min_linear_acceleration>-20.0</min_linear_acceleration>
      <max_angular_acceleration>20.0</max_angular_acceleration>
      <min_angular_acceleration>-20.0</min_angular_acceleration>
      <max_linear_velocity>4.0</max_linear_velocity>
      <min_linear_velocity>-4.0</min_linear_velocity>
      <max_angular_velocity>4.0</max_angular_velocity>
      <min_angular_velocity>-4.0</min_angular_velocity>
    </plugin>

    <plugin filename="libignition-gazebo-joint-state-publisher-system.so" name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>Wheel1J</joint_name>
      <joint_name>Wheel2J</joint_name>
      <joint_name>Wheel3J</joint_name>
      <joint_name>Wheel4J</joint_name>
      <joint_name>camJ</joint_name> 
      <joint_name>imu_joint</joint_name>
      <joint_name>gps_joint</joint_name>
    </plugin>
  </gazebo>
