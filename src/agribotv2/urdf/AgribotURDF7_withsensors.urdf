<!-- ULTRASONIC 1 -->
  <gazebo reference="US1">
    <sensor name="US1_sensor" type="gpu_lidar">
      <pose>0 0 0 -1.5708 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      
      <!-- Force the Frame ID to match ROS -->
      <frame_id>US1</frame_id>
      <gz_frame_id>US1</gz_frame_id> 
      
      <ray>
        <scan>
          <horizontal>
            <samples>60</samples>
            <resolution>1</resolution>
            <min_angle>-0.5236</min_angle>
            <max_angle>0.5236</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.25</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <topic>/ultra/us1</topic>
    </sensor>
  </gazebo>

  <!-- ULTRASONIC 2 -->
  <gazebo reference="US2">
    <sensor name="US2_sensor" type="gpu_lidar">
      <pose>0 0 0 1.5708 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      
      <!-- Force the Frame ID -->
      <frame_id>US2</frame_id>
      <gz_frame_id>US2</gz_frame_id>

      <ray>
        <scan>
          <horizontal>
            <samples>60</samples>
            <resolution>1</resolution>
            <min_angle>-0.5236</min_angle>
            <max_angle>0.5236</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.25</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <topic>/ultra/us2</topic>
    </sensor>
  </gazebo>

  <!-- ULTRASONIC 3 -->
  <gazebo reference="US3">
    <sensor name="US3_sensor" type="gpu_lidar">
      <pose>0 0 0 -1.5708 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      
      <!-- Force the Frame ID -->
      <frame_id>US3</frame_id>
      <gz_frame_id>US3</gz_frame_id>

      <ray>
        <scan>
          <horizontal>
            <samples>60</samples>
            <resolution>1</resolution>
            <min_angle>-0.5236</min_angle>
            <max_angle>0.5236</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.25</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <topic>/ultra/us3</topic>
    </sensor>
  </gazebo>

  <!-- ULTRASONIC 4 -->
  <gazebo reference="US4">
    <sensor name="US4_sensor" type="gpu_lidar">
      <pose>0 0 0 -1.5708 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      
      <!-- Force the Frame ID -->
      <frame_id>US4</frame_id>
      <gz_frame_id>US4</gz_frame_id>

      <ray>
        <scan>
          <horizontal>
            <samples>60</samples>
            <resolution>1</resolution>
            <min_angle>-0.5236</min_angle>
            <max_angle>0.5236</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.25</min>
          <max>4.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <topic>/ultra/us4</topic>
    </sensor>
  </gazebo>

  <!-- CAMERA -->
  <gazebo reference="camera">
    <sensor name="camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      
      <frame_id>camera</frame_id>
      <gz_frame_id>camera</gz_frame_id>

      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <topic>/camera/image_raw</topic>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <frame_id>imu_link</frame_id>
      <topic>/imu</topic>
    </sensor>
    <sensor name="gps_sensor" type="navsat">
      <always_on>1</always_on>
      <update_rate>1</update_rate>
      <topic>/gps/fix</topic>
      <frame_id>gps_link</frame_id>

    </sensor>
  </gazebo>
</robot>