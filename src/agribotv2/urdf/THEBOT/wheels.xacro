<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="wheel_macro" params="name parent xyz rpy">
    <link name="${name}">
      <inertial>
        <origin xyz="0.0003075 0.0035 0.00066" rpy="0 0 0" />
        <mass value="1.03557" />
        <inertia ixx="0.002766" ixy="0" ixz="0" iyy="0.004906" iyz="0" izz="0.002766" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://agribotv2/meshes/${name}.STL" />
        </geometry>
        <material name="">
          <color rgba="0 0 0 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://agribotv2/meshes/${name}.STL" />
        </geometry>
      </collision>
    </link>
    <gazebo reference="${name}">
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <kp>10000000.0</kp>
      <kd>1.0</kd>
      <material>Gazebo/Black</material>
    </gazebo>

    <joint name="${name}J" type="continuous">
      <origin xyz="${xyz}" rpy="${rpy}" />
      <parent link="${parent}" />
      <child link="${name}" />
      <axis xyz="0 1 0" />
      <limit effort="200" velocity="1000" />
      <dynamics damping="0.35" friction="8" />
    </joint>
  </xacro:macro>
</robot>